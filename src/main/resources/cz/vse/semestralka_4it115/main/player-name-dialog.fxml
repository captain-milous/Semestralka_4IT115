<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cz.vse.semestralka_4it115.main.PlayerNameController">
    <padding>
        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
    </padding>
    <children>
        <Label text="Zadej jmeno hrace"/>
        <TextField fx:id="nameField" promptText="Jmeno (1-14 znaku)" onAction="#onConfirm"/>
        <Label fx:id="validationLabel" style="-fx-text-fill: #B71C1C;"/>
        <HBox spacing="8.0">
            <children>
                <Region HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false" onAction="#onCancel" text="Zrusit"/>
                <Button fx:id="confirmButton" mnemonicParsing="false" onAction="#onConfirm" text="Potvrdit"/>
            </children>
        </HBox>
    </children>
</VBox>

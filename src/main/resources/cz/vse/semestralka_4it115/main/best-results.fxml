<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cz.vse.semestralka_4it115.main.BestResultsController">
    <padding>
        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
    </padding>
    <children>
        <Label text="Nejlepsi vysledky (podle penez)"/>
        <TableView fx:id="resultsTable" prefHeight="420.0" prefWidth="650.0">
            <columns>
                <TableColumn fx:id="dateTimeColumn" prefWidth="210.0" text="Datum a cas"/>
                <TableColumn fx:id="playerColumn" prefWidth="190.0" text="Hrac"/>
                <TableColumn fx:id="moneyColumn" prefWidth="110.0" text="Penize"/>
                <TableColumn fx:id="difficultyColumn" prefWidth="130.0" text="Obtiznost"/>
            </columns>
        </TableView>
        <HBox spacing="8.0">
            <children>
                <Region HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false" onAction="#onClose" text="Zavrit"/>
            </children>
        </HBox>
    </children>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cz.vse.semestralka_4it115.main.EndGameController">
    <padding>
        <Insets top="14.0" right="14.0" bottom="14.0" left="14.0"/>
    </padding>
    <children>
        <Label fx:id="titleLabel" text="Konec hry">
            <font>
                <Font size="22.0"/>
            </font>
        </Label>
        <Label fx:id="subtitleLabel" text="Vysledek"/>
        <HBox spacing="10.0">
            <children>
                <Region HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false" onAction="#onExitClicked" text="Ukoncit"/>
                <Button mnemonicParsing="false" onAction="#onRestartClicked" text="Restart"/>
            </children>
        </HBox>
    </children>
</VBox>
